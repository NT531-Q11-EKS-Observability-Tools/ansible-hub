# =====================================================
# Kubernetes (k0s) Inventory - Staging (Example)
# This file is an example inventory.
# Actual inventory is generated automatically by Terraform.
# =====================================================

[k0s_controller]
controller ansible_host=<K0S_CONTROLLER_PRIVATE_IP> ansible_user=ubuntu ansible_ssh_private_key_file=<SSH_PRIVATE_KEY_PATH>

[k0s_workers]
worker-1 ansible_host=<K0S_WORKER_1_PRIVATE_IP> ansible_user=ubuntu ansible_ssh_private_key_file=<SSH_PRIVATE_KEY_PATH>
worker-2 ansible_host=<K0S_WORKER_2_PRIVATE_IP> ansible_user=ubuntu ansible_ssh_private_key_file=<SSH_PRIVATE_KEY_PATH>

[k0s_cluster:children]
k0s_controller
k0s_workers
