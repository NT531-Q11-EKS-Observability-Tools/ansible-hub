    {
      "id": 1,
      "type": "stat",
      "title": "System Total Logs",
      "datasource": "Loki",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"kube-system|monitoring|kube-public|kube-node-lease\"}[$__range]))",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "locale",
          "decimals": 0,
          "noValue": "0",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      }
    },
