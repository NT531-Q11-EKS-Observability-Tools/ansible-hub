{
  "uid": "loki-logs",
  "title": "Loki - System & Application Logs",
  "tags": ["loki", "kubernetes", "logs"],
  "schemaVersion": 37,
  "version": 6,
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "System Total Logs",
      "datasource": "Loki",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"kube-system|monitoring|kube-public|kube-node-lease\"}[$__range]))",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total System Error Logs",
      "datasource": "Loki",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"kube-system|monitoring|kube-public|kube-node-lease\"} |~ \"(?i)(error|exception|failed|panic)\" [$__range]))",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "System Log Volume (by Level)",
      "datasource": "Loki",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 4 },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"kube-system|monitoring|kube-public|kube-node-lease\"} |~ \"(?i)(error|exception|failed|panic)\" [$__interval]))",
          "refId": "A",
          "legendFormat": "ERROR"
        },
        {
          "expr": "sum(count_over_time({namespace=~\"kube-system|monitoring|kube-public|kube-node-lease\"} |~ \"(?i)(warn|warning)\" [$__interval]))",
          "refId": "B",
          "legendFormat": "WARN"
        },
        {
          "expr": "sum(count_over_time({namespace=~\"kube-system|monitoring|kube-public|kube-node-lease\"} !~ \"(?i)(error|exception|failed|panic|warn|warning)\" [$__interval]))",
          "refId": "C",
          "legendFormat": "INFO"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 4,
      "type": "logs",
      "title": "System Logs",
      "datasource": "Loki",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "{namespace=~\"kube-system|monitoring|kube-public|kube-node-lease\"}",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false
      }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "System Error Logs",
      "datasource": "Loki",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "{namespace=~\"kube-system|monitoring|kube-public|kube-node-lease\"} |~ \"(?i)(error|exception|failed|panic)\"",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false
      }
    },
    {
      "id": 6,
      "type": "stat",
