        },
        {
          "expr": "sum(count_over_time({namespace=\"mini-ecommerce\"} !~ \"(?i)(error|exception|failed|panic|warn|warning)\" [$__interval]))",
          "refId": "C",
          "legendFormat": "INFO"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Application Logs (mini-ecommerce)",
      "datasource": "Loki",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "{namespace=\"mini-ecommerce\"}",
          "refId": "A",
