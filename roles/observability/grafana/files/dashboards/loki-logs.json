      "id": 11,
      "title": "System Error %",
      "targets": [
        {
          "expr": "(((sum(count_over_time({namespace=~\"kube-system|monitoring|kube-public|kube-node-lease\", level=\"ERROR\"}[$__range]))) or (sum(count_over_time({namespace=~\"kube-system|monitoring|kube-public|kube-node-lease\"} |~ \"(?i)(error|exception|failed|panic)\" [$__range]))) or vector(0)) / (sum(count_over_time({namespace=~\"kube-system|monitoring|kube-public|kube-node-lease\"}[$__range])) + 1e-9)) * 100",
          "queryType": "instant",
          "refId": "A"
