        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false
      }
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Application Error Logs (mini-ecommerce)",
      "datasource": "Loki",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "{namespace=\"mini-ecommerce\"} |~ \"(?i)(error|exception|failed|panic)\"",
          "refId": "A",
