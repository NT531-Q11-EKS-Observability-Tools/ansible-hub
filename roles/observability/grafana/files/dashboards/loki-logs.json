      "datasource": "Loki",
      "gridPos": { "x": 0, "y": 12, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=\"mini-ecommerce\"}[$__range]))",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Total Application Error Logs (mini-ecommerce)",
      "datasource": "Loki",
      "gridPos": { "x": 6, "y": 12, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=\"mini-ecommerce\"} |~ \"(?i)(error|exception|failed|panic)\" [$__range]))",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Application Log Volume (by Level)",
      "datasource": "Loki",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 4 },
