{
  "uid": "k8s-hpa",
  "title": "Kubernetes HPA Max Replicas",
  "tags": [
    "kubernetes",
    "k0s",
    "hpa"
  ],
  "schemaVersion": 37,
  "version": 1,
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-4h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "HPAs at Max",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(kube_horizontalpodautoscaler_status_current_replicas == bool kube_horizontalpodautoscaler_spec_max_replicas)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Current Replicas",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas",
          "legendFormat": "{{namespace}}/{{horizontalpodautoscaler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Desired Replicas",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_desired_replicas",
          "legendFormat": "{{namespace}}/{{horizontalpodautoscaler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Max Replicas",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 24,
        "h": 6
      },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_spec_max_replicas",
          "legendFormat": "{{namespace}}/{{horizontalpodautoscaler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    }
  ]
}